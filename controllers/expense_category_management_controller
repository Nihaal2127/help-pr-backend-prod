const ExpenseCategory = require("../models/expense_category");
const ExpenseSubcategory = require("../models/expense_subcategory");
const mongoose = require("mongoose");
const Franchise = require("../models/franchise");

const MAX_PAGE_SIZE = 100;

const parsePagination = (query) => {
  let page = parseInt(query.page, 10);
  let limit = parseInt(query.limit, 10);
  if (!Number.isFinite(page) || page < 1) page = 1;
  if (!Number.isFinite(limit) || limit < 1) limit = 10;
  if (limit > MAX_PAGE_SIZE) limit = MAX_PAGE_SIZE;
  return { page, limit, skip: (page - 1) * limit };
};

const parseDateInput = (value) => {
  if (!value) return null;
  const raw = String(value).trim();
  if (!raw) return null;

  const ddmmyyyyMatch = raw.match(/^(\d{2})-(\d{2})-(\d{2}|\d{4})$/);
  if (ddmmyyyyMatch) {
    const day = Number(ddmmyyyyMatch[1]);
    const month = Number(ddmmyyyyMatch[2]);
    const yearPart = ddmmyyyyMatch[3];
    const year = yearPart.length === 2 ? 2000 + Number(yearPart) : Number(yearPart);
    const parsed = new Date(year, month - 1, day);
    if (
      parsed.getFullYear() === year &&
      parsed.getMonth() === month - 1 &&
      parsed.getDate() === day
    ) {
      return parsed;
    }
    return null;
  }

  const parsed = new Date(raw);
  if (Number.isNaN(parsed.getTime())) return null;
  return parsed;
};

const formatSubcategoryRecords = (subcategories) =>
  subcategories.map((subcategory) => ({
    subcategory_id: subcategory._id,
    sub_category_name: subcategory.sub_category_name
  }));

const fetchSubcategoriesForCategory = async (categoryId) =>
  ExpenseSubcategory.find({ category_id: categoryId, deleted_at: null })
    .sort({ created_at: 1 })
    .lean();

const syncSubcategories = async (categoryId, names) => {
  const now = new Date();
  const existing = await ExpenseSubcategory.find({
    category_id: categoryId,
    deleted_at: null
  }).lean();

  const existingByLowerName = new Map();
  for (const subcategory of existing) {
    const key = subcategory.sub_category_name.toLowerCase();
    if (!existingByLowerName.has(key)) {
      existingByLowerName.set(key, subcategory);
    }
  }

  const toKeepIds = new Set();
  for (const name of names) {
    const existingSubcategory = existingByLowerName.get(name.toLowerCase());
    if (existingSubcategory) {
      toKeepIds.add(String(existingSubcategory._id));
      if (existingSubcategory.sub_category_name !== name) {
        await ExpenseSubcategory.updateOne(
          { _id: existingSubcategory._id },
          { $set: { sub_category_name: name, updated_at: now } }
        );
      }
    } else {
      const created = await ExpenseSubcategory.create({
        category_id: categoryId,
        sub_category_name: name
      });
      toKeepIds.add(String(created._id));
    }
  }

  const toDelete = existing.filter((subcategory) => !toKeepIds.has(String(subcategory._id)));
  if (toDelete.length > 0) {
    await ExpenseSubcategory.updateMany(
      { _id: { $in: toDelete.map((subcategory) => subcategory._id) } },
      { $set: { deleted_at: now, updated_at: now } }
    );
  }
};

const updateFirstSubcategory = async (categoryId, name) => {
  const now = new Date();
  let subcategory = await ExpenseSubcategory.findOne({
    category_id: categoryId,
    deleted_at: null
  }).sort({ created_at: 1 });

  if (!subcategory) {
    subcategory = new ExpenseSubcategory({
      category_id: categoryId,
      sub_category_name: name
    });
  } else {
    subcategory.sub_category_name = name;
    subcategory.updated_at = now;
  }

  await subcategory.save();
};

const create = async (req, res) => {
  try {
    const { franchise_id, category_name, description } = req.body;
    const subCategoryNames = req.subCategoryNames || [];

    const franchise = await Franchise.findOne({ _id: franchise_id, deleted_at: null }).lean();
    if (!franchise) {
      return res.status(404).json({
        success: false,
        status: 404,
        message: "Franchise not found."
      });
    }

    const existingCategory = await ExpenseCategory.findOne({
      franchise_id,
      category_name,
      deleted_at: null
    });

    if (existingCategory) {
      return res.status(409).json({
        success: false,
        status: 409,
        message: "Category name already exists."
      });
    }

    const category = new ExpenseCategory({
      franchise_id,
      category_name,
      description
    });
    const savedCategory = await category.save();

    const savedSubcategories = await ExpenseSubcategory.insertMany(
      subCategoryNames.map((sub_category_name) => ({
        category_id: savedCategory._id,
        sub_category_name
      }))
    );

    const subcategories = savedSubcategories.map((subcategory) => ({
      subcategory_id: subcategory._id,
      sub_category_name: subcategory.sub_category_name
    }));
    const firstSubcategory = subcategories[0] || null;

    return res.status(201).json({
      success: true,
      status: 201,
      message: "Expense category created successfully.",
      record: {
        _id: savedCategory._id,
        franchise_id: savedCategory.franchise_id,
        category_name: savedCategory.category_name,
        description: savedCategory.description,
        subcategories,
        sub_category_name: firstSubcategory ? firstSubcategory.sub_category_name : null,
        subcategory_id: firstSubcategory ? firstSubcategory.subcategory_id : null,
        created_at: savedCategory.created_at,
        updated_at: savedCategory.updated_at
      }
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      status: 500,
      message: "Internal server error."
    });
  }
};

const getAll = async (req, res) => {
  try {
    const { page, limit, skip } = parsePagination(req.query);
    const search = req.query.search ? String(req.query.search).trim() : "";
    const franchiseId = req.query.franchise_id ? String(req.query.franchise_id).trim() : "";
    const startDate = req.query.startDate ? String(req.query.startDate).trim() : "";
    const endDate = req.query.endDate ? String(req.query.endDate).trim() : "";
    const sortKeyRaw = req.query.sort_by || req.query.sort;
    const sortBy = sortKeyRaw ? String(sortKeyRaw).trim() : "created_at";
    const sortOrder = req.query.sort_order === "asc" ? 1 : -1;

    const allowedSortFields = {
      id: "_id",
      category: "category_name",
      subcategory: "sub_category_name",
      created_at: "created_at",
      date: "created_at"
    };
    const sortField = allowedSortFields[sortBy] || "created_at";

    const pipeline = [
      {
        $match: {
          deleted_at: null
        }
      },
      {
        $lookup: {
          from: ExpenseSubcategory.collection.name,
          let: { categoryId: "$_id" },
          pipeline: [
            {
              $match: {
                $expr: {
                  $and: [
                    { $eq: ["$category_id", "$$categoryId"] },
                    { $eq: ["$deleted_at", null] }
                  ]
                }
              }
            },
            {
              $sort: { created_at: 1 }
            }
          ],
          as: "subcategories"
        }
      },
      {
        $addFields: {
          sub_category_name: {
            $ifNull: [{ $arrayElemAt: ["$subcategories.sub_category_name", 0] }, null]
          }
        }
      }
    ];

    if (franchiseId && mongoose.Types.ObjectId.isValid(franchiseId)) {
      pipeline.push({
        $match: {
          franchise_id: new mongoose.Types.ObjectId(franchiseId)
        }
      });
    }

    if (startDate || endDate) {
      const createdAtFilter = {};

      if (startDate && !endDate) {
        const start = parseDateInput(startDate);
        if (start) {
          const dayStart = new Date(start);
          dayStart.setHours(0, 0, 0, 0);
          const dayEnd = new Date(start);
          dayEnd.setHours(23, 59, 59, 999);
          createdAtFilter.$gte = dayStart;
          createdAtFilter.$lte = dayEnd;
        }
      } else {
        if (startDate) {
          const start = parseDateInput(startDate);
          if (start) {
            start.setHours(0, 0, 0, 0);
            createdAtFilter.$gte = start;
          }
        }

        if (endDate) {
          const end = parseDateInput(endDate);
          if (end) {
            end.setHours(23, 59, 59, 999);
            createdAtFilter.$lte = end;
          }
        }
      }

      if (Object.keys(createdAtFilter).length > 0) {
        pipeline.push({
          $match: {
            created_at: createdAtFilter
          }
        });
      }
    }

    if (search) {
      pipeline.push({
        $match: {
          $or: [
            {
              $expr: {
                $regexMatch: {
                  input: { $toString: "$_id" },
                  regex: search,
                  options: "i"
                }
              }
            },
            { category_name: { $regex: search, $options: "i" } },
            { "subcategories.sub_category_name": { $regex: search, $options: "i" } },
            {
              $expr: {
                $regexMatch: {
                  input: {
                    $dateToString: {
                      format: "%Y-%m-%d %H:%M:%S",
                      date: "$created_at"
                    }
                  },
                  regex: search,
                  options: "i"
                }
              }
            }
          ]
        }
      });
    }

    pipeline.push(
      { $sort: { [sortField]: sortOrder } },
      {
        $facet: {
          metadata: [{ $count: "totalItems" }],
          records: [
            { $skip: skip },
            { $limit: limit },
            {
              $project: {
                _id: 1,
                franchise_id: 1,
                category_name: 1,
                description: 1,
                subcategories: {
                  $map: {
                    input: "$subcategories",
                    as: "sub",
                    in: {
                      subcategory_id: "$$sub._id",
                      sub_category_name: "$$sub.sub_category_name"
                    }
                  }
                },
                sub_category_name: 1,
                subcategory_id: { $arrayElemAt: ["$subcategories._id", 0] },
                created_at: 1,
                updated_at: 1
              }
            }
          ]
        }
      }
    );

    const aggregatedResult = await ExpenseCategory.aggregate(pipeline);
    const firstResult = aggregatedResult[0] || { metadata: [], records: [] };
    const totalItems = firstResult.metadata[0] ? firstResult.metadata[0].totalItems : 0;
    const totalPages = Math.ceil(totalItems / limit);
    const records = firstResult.records || [];

    return res.status(200).json({
      success: true,
      status: 200,
      message: "Expense category list fetched successfully.",
      totalItems,
      totalPages,
      currentPage: page,
      records
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      status: 500,
      message: "Internal server error."
    });
  }
};

const getById = async (req, res) => {
  try {
    const { id } = req.params;

    const category = await ExpenseCategory.findOne({ _id: id, deleted_at: null }).lean();

    if (!category) {
      return res.status(404).json({
        success: false,
        status: 404,
        message: "Expense category not found."
      });
    }

    const formattedSubcategories = formatSubcategoryRecords(
      await fetchSubcategoriesForCategory(category._id)
    );
    const firstSubcategory = formattedSubcategories[0] || null;

    return res.status(200).json({
      success: true,
      status: 200,
      message: "Expense category fetched successfully.",
      record: {
        _id: category._id,
        franchise_id: category.franchise_id,
        category_name: category.category_name,
        description: category.description,
        subcategories: formattedSubcategories,
        sub_category_name: firstSubcategory ? firstSubcategory.sub_category_name : null,
        subcategory_id: firstSubcategory ? firstSubcategory.subcategory_id : null,
        created_at: category.created_at,
        updated_at: category.updated_at
      }
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      status: 500,
      message: "Internal server error."
    });
  }
};

const update = async (req, res) => {
  try {
    const { id } = req.params;
    const { franchise_id, category_name, sub_category_name, description } = req.body;
    const subCategoryNames = req.subCategoryNames;
    const subCategoryUpdateMode = req.subCategoryUpdateMode;

    const category = await ExpenseCategory.findOne({ _id: id, deleted_at: null });

    if (!category) {
      return res.status(404).json({
        success: false,
        status: 404,
        message: "Expense category not found."
      });
    }

    if (franchise_id !== undefined) {
      const franchise = await Franchise.findOne({ _id: franchise_id, deleted_at: null }).lean();
      if (!franchise) {
        return res.status(404).json({
          success: false,
          status: 404,
          message: "Franchise not found."
        });
      }
      category.franchise_id = franchise_id;
    }

    if (category_name || franchise_id !== undefined) {
      const duplicate = await ExpenseCategory.findOne({
        _id: { $ne: id },
        franchise_id: category.franchise_id,
        category_name: category_name || category.category_name,
        deleted_at: null
      });

      if (duplicate) {
        return res.status(409).json({
          success: false,
          status: 409,
          message: "Category name already exists."
        });
      }
      category.category_name = category_name;
    }

    if (description !== undefined) {
      category.description = description;
    }

    category.updated_at = new Date();
    const updatedCategory = await category.save();

    if (sub_category_name !== undefined) {
      if (subCategoryUpdateMode === "sync") {
        await syncSubcategories(updatedCategory._id, subCategoryNames);
      } else {
        await updateFirstSubcategory(updatedCategory._id, subCategoryNames[0]);
      }
    }

    const formattedSubcategories = formatSubcategoryRecords(
      await fetchSubcategoriesForCategory(updatedCategory._id)
    );
    const firstSubcategory = formattedSubcategories[0] || null;

    return res.status(200).json({
      success: true,
      status: 200,
      message: "Expense category updated successfully.",
      record: {
        _id: updatedCategory._id,
        franchise_id: updatedCategory.franchise_id,
        category_name: updatedCategory.category_name,
        description: updatedCategory.description,
        subcategories: formattedSubcategories,
        sub_category_name: firstSubcategory ? firstSubcategory.sub_category_name : null,
        subcategory_id: firstSubcategory ? firstSubcategory.subcategory_id : null,
        created_at: updatedCategory.created_at,
        updated_at: updatedCategory.updated_at
      }
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      status: 500,
      message: "Internal server error."
    });
  }
};

const remove = async (req, res) => {
  try {
    const { id } = req.params;

    const category = await ExpenseCategory.findOne({ _id: id, deleted_at: null });

    if (!category) {
      return res.status(404).json({
        success: false,
        status: 404,
        message: "Expense category not found."
      });
    }

    const now = new Date();
    category.deleted_at = now;
    category.updated_at = now;
    await category.save();

    await ExpenseSubcategory.updateMany(
      { category_id: id, deleted_at: null },
      { $set: { deleted_at: now, updated_at: now } }
    );

    return res.status(200).json({
      success: true,
      status: 200,
      message: "Expense category deleted successfully."
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      status: 500,
      message: "Internal server error."
    });
  }
};

module.exports = { create, getAll, getById, update, remove };
